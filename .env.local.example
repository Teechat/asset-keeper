# LINE Messaging API (get from developers.line.biz)
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# LINE LIFF (get from developers.line.biz after creating a LIFF app)
NEXT_PUBLIC_LIFF_ID=your_liff_id_here

# Supabase (get from supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App URL (your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Cron secret (any random string — used to protect /api/reminders endpoint)
CRON_SECRET=your_random_secret_here
